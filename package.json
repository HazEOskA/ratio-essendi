{
  "name": "ratio-essendi",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "System-of-systems architecture foundation for Ratio Essendi / Product Factory Core.",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "docs:check": "echo 'Docs-only architecture lock. No build yet.'",
    "typecheck": "tsc --noEmit",
    "proof": "tsx tests/proof.ts",
    "factory": "tsx tests/factory-run.ts",
    "offer": "tsx tests/offer-run.ts",
    "judge": "tsx tests/judge-run.ts",
    "prospects": "tsx tests/prospect-run.ts",
    "dashboard": "tsx tests/dashboard-run.ts",
    "dashboard:serve": "tsx tests/dashboard-serve.ts",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [
    "ratio-essendi",
    "product-factory",
    "system-of-systems",
    "agent-succession",
    "core-cells",
    "failover",
    "drift-rule"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
